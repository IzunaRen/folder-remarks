{
  "name": "folder-remarks",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.35",
  "publisher": "Andrew-s",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trae-demo/folder-remarks"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:folderRemarksRemarkedTree",
    "onCommand:folderRemarks.setRemark",
    "onCommand:folderRemarks.addRemark",
    "onCommand:folderRemarks.editRemark",
    "onCommand:folderRemarks.deleteRemark",
    "onCommand:folderRemarks.revealActiveFile",
    "onCommand:folderRemarks.treeRefresh",
    "onCommand:folderRemarks.treeOpenToSide",
    "onCommand:folderRemarks.treeRevealInExplorer",
    "onCommand:folderRemarks.treeRevealInOS",
    "onCommand:folderRemarks.treeCopyRelativePath",
    "onCommand:folderRemarks.treeCopyAbsolutePath",
    "onCommand:folderRemarks.treeRename",
    "onCommand:folderRemarks.treeDelete",
    "onCommand:folderRemarks.treeNewFile",
    "onCommand:folderRemarks.treeNewFolder",
    "onCommand:folderRemarks.openResource",
    "onCommand:folderRemarks.openFolder",
    "onCommand:folderRemarks.manageRemarks",
    "onCommand:folderRemarks.debugPing"
  ],
  "contributes": {
    "commands": [
      {
        "command": "folderRemarks.setRemark",
        "title": "%command.setRemark.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.deleteRemark",
        "title": "%command.deleteRemark.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.checkBadges",
        "title": "%command.checkBadges.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.openFolder",
        "title": "%command.openFolder.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.openResource",
        "title": "%command.openResource.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.manageRemarks",
        "title": "%command.manageRemarks.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.revealActiveFile",
        "title": "%command.revealActiveFile.title%",
        "category": "%command.category%",
        "icon": "$(target)"
      },
      {
        "command": "folderRemarks.treeRefresh",
        "title": "%command.treeRefresh.title%",
        "category": "%command.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "folderRemarks.treeOpenToSide",
        "title": "%command.treeOpenToSide.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.treeRevealInExplorer",
        "title": "%command.treeRevealInExplorer.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.treeRevealInOS",
        "title": "%command.treeRevealInOS.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.treeCopyRelativePath",
        "title": "%command.treeCopyRelativePath.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.treeCopyAbsolutePath",
        "title": "%command.treeCopyAbsolutePath.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.treeRename",
        "title": "%command.treeRename.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.treeDelete",
        "title": "%command.treeDelete.title%",
        "category": "%command.category%"
      },
      {
        "command": "folderRemarks.treeNewFile",
        "title": "%command.treeNewFile.title%",
        "category": "%command.category%",
        "icon": "$(new-file)"
      },
      {
        "command": "folderRemarks.treeNewFolder",
        "title": "%command.treeNewFolder.title%",
        "category": "%command.category%",
        "icon": "$(new-folder)"
      },
      {
        "command": "folderRemarks.debugPing",
        "title": "%command.debugPing.title%",
        "category": "%command.category%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "folderRemarks",
          "title": "%viewsContainer.title%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "folderRemarks": [
        {
          "id": "folderRemarksRemarkedTree",
          "name": "%view.folderRemarks.name%"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "folderRemarks.setRemark",
          "when": "resourceScheme == 'file'",
          "group": "z_folderRemarks@99"
        },
        {
          "command": "folderRemarks.deleteRemark",
          "when": "resourceScheme == 'file'",
          "group": "z_folderRemarks@100"
        }
      ],
      "editor/title/context": [
        {
          "command": "folderRemarks.setRemark",
          "when": "resourceScheme == 'file'",
          "group": "z_folderRemarks@99"
        },
        {
          "command": "folderRemarks.deleteRemark",
          "when": "resourceScheme == 'file'",
          "group": "z_folderRemarks@100"
        }
      ],
      "view/item/context": [
        {
          "command": "folderRemarks.setRemark",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == resourceNodeDir || viewItem == remarkedNodeFile || viewItem == remarkedNodeDir)",
          "group": "inline@5"
        },
        {
          "command": "folderRemarks.deleteRemark",
          "when": "view == folderRemarksRemarkedTree && (viewItem == remarkedNodeFile || viewItem == remarkedNodeDir)",
          "group": "inline@6"
        },
        {
          "command": "folderRemarks.openResource",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == remarkedNodeFile)",
          "group": "navigation@1"
        },
        {
          "command": "folderRemarks.treeOpenToSide",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == remarkedNodeFile)",
          "group": "navigation@2"
        },
        {
          "command": "folderRemarks.treeRevealInExplorer",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == resourceNodeDir || viewItem == remarkedNodeFile || viewItem == remarkedNodeDir)",
          "group": "navigation@3"
        },
        {
          "command": "folderRemarks.treeRevealInOS",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == resourceNodeDir || viewItem == remarkedNodeFile || viewItem == remarkedNodeDir)",
          "group": "navigation@4"
        },
        {
          "command": "folderRemarks.treeCopyRelativePath",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == resourceNodeDir || viewItem == remarkedNodeFile || viewItem == remarkedNodeDir)",
          "group": "3_copy@1"
        },
        {
          "command": "folderRemarks.treeCopyAbsolutePath",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == resourceNodeDir || viewItem == remarkedNodeFile || viewItem == remarkedNodeDir)",
          "group": "3_copy@2"
        },
        {
          "command": "folderRemarks.treeRename",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == resourceNodeDir || viewItem == remarkedNodeFile || viewItem == remarkedNodeDir)",
          "group": "4_edit@1"
        },
        {
          "command": "folderRemarks.treeDelete",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeFile || viewItem == resourceNodeDir || viewItem == remarkedNodeFile || viewItem == remarkedNodeDir)",
          "group": "4_edit@2"
        },
        {
          "command": "folderRemarks.treeNewFile",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeDir || viewItem == remarkedNodeDir)",
          "group": "5_new@1"
        },
        {
          "command": "folderRemarks.treeNewFolder",
          "when": "view == folderRemarksRemarkedTree && (viewItem == resourceNodeDir || viewItem == remarkedNodeDir)",
          "group": "5_new@2"
        }
      ],
      "view/title": [
        {
          "command": "folderRemarks.revealActiveFile",
          "when": "view == folderRemarksRemarkedTree",
          "group": "navigation@1"
        },
        {
          "command": "folderRemarks.treeRefresh",
          "when": "view == folderRemarksRemarkedTree",
          "group": "navigation@2"
        },
        {
          "command": "folderRemarks.treeNewFile",
          "when": "view == folderRemarksRemarkedTree",
          "group": "navigation@3"
        },
        {
          "command": "folderRemarks.treeNewFolder",
          "when": "view == folderRemarksRemarkedTree",
          "group": "navigation@4"
        }
      ],
      "commandPalette": [
        {
          "command": "folderRemarks.setRemark"
        },
        {
          "command": "folderRemarks.manageRemarks"
        },
        {
          "command": "folderRemarks.checkBadges"
        },
        {
          "command": "folderRemarks.revealActiveFile"
        },
        {
          "command": "folderRemarks.treeRefresh"
        },
        {
          "command": "folderRemarks.debugPing"
        }
      ]
    },
    "keybindings": [
      {
        "command": "folderRemarks.setRemark",
        "key": "alt+e",
        "when": "explorerViewletVisible || filesExplorerFocus || editorTextFocus"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "folderRemarks.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-cn"
          ],
          "enumDescriptions": [
            "%configuration.language.auto%",
            "%configuration.language.en%",
            "%configuration.language.zhCn%"
          ],
          "description": "%configuration.language.description%"
        },
        "folderRemarks.displayPathStyle": {
          "type": "string",
          "default": "relative",
          "enum": [
            "relative",
            "absolute"
          ],
          "enumDescriptions": [
            "%configuration.displayPathStyle.relative%",
            "%configuration.displayPathStyle.absolute%"
          ],
          "description": "%configuration.displayPathStyle.description%"
        },
        "folderRemarks.autoRevealActiveFile": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoRevealActiveFile.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf out .tsbuildinfo",
    "typecheck": "tsc -p . --noEmit",
    "build": "tsc -p .",
    "lint": "eslint src",
    "test:unit": "vitest run",
    "test:integration": "node ./out/test/runTest.js",
    "test": "npm run test:unit && npm run build && npm run test:integration",
    "package": "vsce package --no-dependencies"
  },
  "overrides": {
    "esbuild": "^0.25.1",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "glob": "^10.4.5",
    "mocha": "^10.3.0",
    "prettier": "^3.2.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
  }
}
